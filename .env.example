# === Stroom environment ===
# Copy to .env and fill in values. Never commit .env.
# Generate secrets with: openssl rand -base64 32

# --- Fase 0 (infra): required now ---

# Postgres password for the 'stroom' DB user
STROOM_DB_PASSWORD=

# API service (intern, opgebouwd uit STROOM_DB_PASSWORD)
DATABASE_URL=postgresql://stroom:<zet-STROOM_DB_PASSWORD-hier>@stroom-db:5432/stroom
ASYNC_DATABASE_URL=postgresql+asyncpg://stroom:<zet-STROOM_DB_PASSWORD-hier>@stroom-db:5432/stroom

# Master key for the LiteLLM proxy (used in Authorization: Bearer <...>)
LITELLM_MASTER_KEY=

# Anthropic API key — used by stroom-deep (Opus 4.7) for "Dieper" chat & podcast scripts
# Get at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Gemini API key — used by stroom-long-context (Gemini 3.1 Pro) for monthly episodes
# Get at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Where Ollama is reachable FROM INSIDE the LiteLLM container.
# - Ollama on the same host as Docker:  http://host.docker.internal:11434
# - Ollama on a different host (Tailscale): http://<tailscale-hostname>:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434

# --- Fase 2+ (fill in when you get there) ---

# YouTube Data API v3 key — Fase 2 playlist poller
# Get at https://console.cloud.google.com/ (enable YouTube Data API v3)
YOUTUBE_API_KEY=

# Obsidian Local REST API — Fase 5 (writer)
# From the Local REST API plugin settings inside Obsidian
OBSIDIAN_BASE_URL=http://host.docker.internal:27124
OBSIDIAN_API_KEY=

# Vikunja API — Fase 6 (todo sync)
VIKUNJA_URL=
VIKUNJA_TOKEN=
VIKUNJA_DEFAULT_PROJECT_ID=1

# --- Queue tunables (optional; defaults shown) ---
#
# Hard cap op aantal items in de summarize-pipeline (queued + actief).
# Cron weigert te queueen boven deze grens — voorkomt dat de VPS vastloopt
# bij grote backlogs. 30 ≈ wat je per dag aankunt qua leeswerk.
SUMMARIZE_QUEUE_MAX_DEPTH=30

# Idem voor transcribe (single GPU). Veiligheidsmarge boven 1 actief.
TRANSCRIBE_QUEUE_MAX_DEPTH=30

# Aantal parallelle summarize-workers. = max gelijktijdige LLM-calls
# voor bulk-summarize. 2 is safe op een kleine VPS.
SUMMARIZE_WORKERS=2

# Timeout per LLM-call (seconden). Korter = snellere failure ipv hangen.
LLM_HTTP_TIMEOUT_SEC=60

# Connection-pool limit voor LLM-client. Houd >= SUMMARIZE_WORKERS.
LLM_MAX_CONCURRENT=4

# Hoe vaak een idle worker pollt naar nieuwe queue-items (seconden).
WORKER_IDLE_POLL_SEC=10

# Memory-gate: workers weigeren een item te claimen als host-RAM onder
# de drempel zit. Voorkomt OOM op kleine VPS waar Whisper en de baseline
# samen over de RAM-ceiling gaan. MemAvailable uit /proc/meminfo (host-stat).
#
# Whisper-medium peak ~1.6GB host-RAM (model + wav2vec2 alignment + audio
# buffer). 2000MB drempel = Whisper + 400MB safety margin. Verhoog als de
# baseline van andere stacks groeit.
TRANSCRIBE_MIN_FREE_MB=2000

# LiteLLM/Ollama-call piek is veel kleiner (~150-300MB). 500MB drempel
# voorkomt dat summarize tijdens een echte geheugendruk-crisis nog meer
# erbij zet. Verlaag naar 0 om de gate effectief uit te schakelen.
SUMMARIZE_MIN_FREE_MB=500
