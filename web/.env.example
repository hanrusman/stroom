# Web client environment (Vite). Copy to .env for local dev.
#
# Do NOT put provider API keys (Gemini/Anthropic/etc.) here. Anything Vite reads
# at build time can end up in the public JS bundle. Cloud LLM calls run
# server-side via the LiteLLM proxy, so the browser never needs a provider key.

# Comma-separated extra hostnames the Vite dev server accepts.
# Example: VITE_ALLOWED_HOSTS=stroom.example.com
VITE_ALLOWED_HOSTS=
